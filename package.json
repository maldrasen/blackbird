{
  "name": "blackbird",
  "version": "0.0.0",
  "description": "A Lewd Dungeon Crawler",
  "author": "Maldrasen",
  "homepage": "https://gitlab.com/distant-thunder/blackbird",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@gitlab.com/distant-thunder/blackbird.git"
  },
  "type": "commonjs",
  "main": "main.js",
  "build": {
    "appId": "distant-thunder.blackbird",
    "win": {
      "target": [{
        "target": "portable",
        "arch": ["x64"]
      }]
    }
  },
  "scripts": {
    "start": "electron . --development",
    "dist": "electron-builder",
    "sass": "sass",
    "test": "node bin/run-tests.js",
    "coverage": "c8 npm test"
  },
  "c8": {
    "reporter": ["text", "cobertura", "html"],
    "include": ["application/**"],
    "exclude": ["application/views/**", "application/test/**"]
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "chai": "4.5.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "mocha": "11.7.5",
    "sass": "1.97.3"
  }
}
